# Optional: override the Go binary path (supports absolute, relative, or ~ paths)
# SMP_BINARY_PATH=~/social-media-models/smp

# Optional: override the simulation results output directory (supports absolute, relative, or ~ paths)
# SMP_BASE_PATH=./run

# Optional: override the statistics database path (LMDB directory, default $SMP_BASE_PATH/stats.lmdb)
# SMP_DB_PATH=./run/stats.lmdb

# Optional: override the plot output directory (default $SMP_BASE_PATH/plots)
# SMP_PLOTS_PATH=./run/plots
